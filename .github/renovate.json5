{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    'docker:enableMajor',
    'helpers:pinGitHubActionDigests',
    'github>mcsrobert/homelab//.github/renovate/ansible-galaxy.json5',
    'github>mcsrobert/homelab//.github/renovate/commit-message.json5',
    'github>mcsrobert/homelab//.github/renovate/custom-managers.json5',
    'github>mcsrobert/homelab//.github/renovate/merge-schedule.json5',
    'github>mcsrobert/homelab//.github/renovate/groups.json5',
    'github>mcsrobert/homelab//.github/renovate/pr-labels.json5',
    ':dependencyDashboard',
    ':disableRateLimiting',
    ':enablePreCommit',
  ],
  timezone: 'Europe/Amsterdam',
  dependencyDashboardTitle: 'Renovate Dashboard 🤖',
  prTitleStrict: true,
  commitBodyTable: true,
  rebaseWhen: 'auto',
  platformCommit: 'enabled',
  suppressNotifications: [
    'prEditedNotification',
    'prIgnoreNotification',
  ],
  flux: {
    managerFilePatterns: ['/\\.ya?ml$/'],
  },
  'helm-values': {
    managerFilePatterns: ['/\\.ya?ml(\\.j2)?$/'],
  },
  packageRules: [
    {
      description: 'Pin docker images from helm-values',
      matchManagers: ['helm-values'],
      matchDatasources: ['docker'],
      pinDigests: true,
    },
    {
      description: 'Use 5 part versioning scheme for CNPG VectorChord image',
      matchDatasources: ['docker'],
      matchPackageNames: ['ghcr.io/tensorchord/cloudnative-vectorchord'],
      versioning: 'regex:^(?<major>\\d+)\\.(?<minor>\\d+)-(?<patch>\\d+)\\.(?<build>\\d+)\\.(?<revision>\\d+)$',
      pinDigests: true,
    },
  ],
}
