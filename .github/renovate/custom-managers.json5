{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  customManagers: [
    {
      description: 'Process annotated dependencies',
      customType: 'regex',
      managerFilePatterns: ['/\\.ya?ml(\\.j2)?$/'],
      matchStrings: ['datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\n.*[:=]\\s*["\']?(?<currentValue>[^"\'\\s]+)["\']?'],
      versioningTemplate: 'semver-coerced',
    },
    {
      description: 'Update YAML schema for kubernetes manifests based on k3s version',
      customType: 'regex',
      managerFilePatterns: ['/\\.ya?ml$/'],
      matchStrings: ['yannh/kubernetes-json-schema/master/(?<currentValue>v\\d+\\.\\d+\\.\\d+)'],
      datasourceTemplate: 'github-releases',
      depNameTemplate: 'kubernetes/kubernetes',
    },
    {
      description: 'Update YAML schema for helm releases with app-template chart',
      customType: 'regex',
      managerFilePatterns: ['/helm-?release\\.ya?ml$/'],
      matchStrings: ['bjw-s-labs/helm-charts/app-template-(?<currentValue>\\d+\\.\\d+\\.\\d+)'],
      datasourceTemplate: 'docker',
      depNameTemplate: 'ghcr.io/bjw-s-labs/helm/app-template',
      versioningTemplate: 'semver',
    },
    {
      description: 'Update YAML schema for Blocky configuration',
      customType: 'regex',
      managerFilePatterns: ['/blocky\/app\/resources\/config\\.ya?ml$/'],
      matchStrings: ['0xerr0r\\.github\\.io/blocky/(?<currentValue>v\\d+\\.\\d+\\.\\d+)/config\\.schema\\.json'],
      datasourceTemplate: 'docker',
      depNameTemplate: 'ghcr.io/0xerr0r/blocky',
      versioningTemplate: 'semver',
    },
  ]
}
