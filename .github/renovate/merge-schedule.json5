{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  packageRules: [
    {
      description: 'All releases are at least 14d old',
      matchPackageNames: ['*'],
      minimumReleaseAge: '14d',
    },
    {
      description: 'Auto merge patch releases on weekdays',
      matchUpdateTypes: ['patch'],
      matchCurrentVersion: '>=1.0.0',
      schedule: ['* 12-13 * * 0-4'],
      automerge: true,
      automergeSchedule: ['* 10-11 * * 1-5'],
    },
    {
      description: 'Group and auto merge Dev & CI dependencies weekly',
      groupName: 'Dev & CI dependencies',
      matchFileNames: [
        '.github/**',
        'ansible/requirements.yml',
        '.pre-commit-config.yaml',
      ],
      schedule: ['* 7-8 * * 3'],
      automerge: true,
      automergeSchedule: ['* 14-15 * * 2'],
    },
  ]
}
