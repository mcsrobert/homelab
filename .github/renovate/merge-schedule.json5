{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  respectLatest: false,
  packageRules: [
    {
      description: 'Auto merge patch releases twice a month',
      matchDatasources: ['docker', 'helm'],
      matchUpdateTypes: ['patch'],
      schedule: ['on the 4th and 19th day of the month'],
      automerge: true,
      automergeSchedule: [
        'on the 1st, 2nd, 3rd, 15th, 16th, 17th day of the month',
        'between 11:00 and 14:00',
        'every weekday',
      ],
    },
    {
      description: 'Group and auto merge Dev & CI dependencies once a month',
      groupName: 'Dev & CI dependencies',
      matchFileNames: [
        '.github/**',
        'ansible/requirements.yml',
        '.pre-commit-config.yaml',
      ],
      schedule: ['on the 4th day of the month'],
      automerge: true,
      automergeSchedule: [
        'on the 1st, 2nd, 3rd day of the month',
        'between 15:00 and 17:00',
        'every weekday',
      ],
    },
  ]
}
